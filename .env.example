# API Keys
# 前往以下网站获取你的 API Key:
# - Qwen: https://dashscope.aliyun.com/
# - DeepSeek: https://platform.deepseek.com/

QWEN_API_KEY=your_qwen_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# RSS Sources  
# 填入你的 RSS 链接（支持多个，用英文逗号分隔）
#
# 推荐来源：
# - ForgeRSS (https://github.com/tmwgsicp/ForgeRSS) - 开源RSS工具
# - wechat-download-api (https://github.com/tmwgsicp/wechat-download-api) - 微信公众号RSS订阅
# - Feedly, Inoreader - RSS聚合服务
# - 博客原生RSS、新闻网站RSS等
#
# 示例：
# 单个RSS源：
# RSS_FEED_URLS=https://example.com/feed.xml
#
# 多个RSS源（用逗号分隔）：
# RSS_FEED_URLS=https://blog1.com/feed.xml,https://blog2.com/feed.xml,https://blog3.com/feed.xml

RSS_FEED_URLS=https://your-rss-feed-url.com/feed.xml

# Output Settings
# 蒸馏结果保存目录
OUTPUT_DIR=./output
